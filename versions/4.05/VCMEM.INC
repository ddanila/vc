	PUSH	DX
	PUSH	AX
	MOV	AX,7+12+1+MaxVect
	MUL	BP
	ADD	AX,OFFSET MemList
	MOV	SI,AX
	POP	AX
	POP	DX
	RET
MemAddr	ENDP

MemColr	PROC	NEAR			; Set color
	PUSH	DI
	MOV	DI,OFFSET Memo_P
	ADD	DI,AX
	MOV	AL,' '
	TEST	BYTE PTR DS:[SI],1
	JZ	MemCo1
	MOV	AL,''
	TEST	BYTE PTR DS:[SI],2
	JZ	MemCo1
	INC	DI
	MOV	AL,'ű'
MemCo1:	MOV	AH,CS:[DI]
	CALL	Color
	POP	DI
	RET
MemColr	ENDP

MemCurs	PROC	NEAR			; Set/Reset cursor
	PUSH	DI
	PUSH	DX
	PUSH	BX
	MOV	CX,BP
	SUB	CX,DI
	ADD	BH,CL
	ADD	BX,405h
	SUB	DL,12
	MOV	CL,DL
	MOV	CH,0
	CALL	MemAddr
	CALL	MemColr
	CALL	BasAdr
	MOV	DS:[DI],AL
	MOV	AL,AH
	CALL	MvsColr
	MOV	DH,1
	CALL	Window
	POP	BX
	POP	DX
	POP	DI
	RET
MemCurs	ENDP

MemEnd	PROC	NEAR			; Find end
	INC	BP
	CALL	MemAddr
	CMP	WORD PTR DS:[SI+1],0
	JNE	MemEnd
	RET
MemEnd	ENDP

MemItem	PROC	NEAR			; Output item
	PUSH	DI
	PUSH	DX
	PUSH	CX
	PUSH	BX
	CALL	BasAdr
	XOR	AX,AX
	CALL	MemColr
	MOV	CL,DL
	SUB	CL,12
	MOV	CH,0
	PUSH	DI
	PUSH	AX
	MOV	AL,' '
	REP	STOSW
	POP	AX
	POP	DI
	CMP	WORD PTR DS:[SI+1],0
	JNE	MemIt1
	JMP	MemIt4
MemIt1:	INC	SI
	STOSW
	INC	DI
	INC	DI
	LODSB
	PUSH	AX
	LODSB
	CALL	HexByt
	POP	AX
	CALL	HexByt
	PUSH	DI
	LODSW
	XOR	BX,BX
	MOV	CX,AX
	MOV	DI,OFFSET TmpBuf
	MOV	AL,2
	CALL	Number
	LODSW
	MOV	BL,AH
	MOV	BH,0
	MOV	CL,4
	SHR	BL,CL
	SHL	AX,CL
	MOV	CX,AX
	MOV	DI,OFFSET TmpBuf+20
	MOV	AL,3
	CALL	Number
	POP	DI
	PUSH	SI
	MOV	SI,OFFSET TmpBuf+4
	MOV	CX,6
	MOV	AH,DS:[DI+1]
	CALL	MvsBwe
	MOV	SI,OFFSET TmpBuf+23
	MOV	CX,10
	CALL	MvsBwe
	POP	SI
	ADD	DI,2*3
	MOV	CX,12
	CALL	MvsBwe
	LODSB
	MOV	CX,MaxVect
	PUSH	SI
	ADD	DI,2*2
MemIt2:	CMP	AL,0
	JE	MemIt3
	INC	DI
	INC	DI
	PUSH	AX
	LODSB
	CALL	HexByt
	POP	AX
	DEC	AX
	LOOP	MemIt2
	JE	MemIt3
	SUB	DI,2*2
	MOV	AL,'.'
	STOSB
	INC	DI
	STOSB
	INC	DI
	STOSB
MemIt3:	POP	SI
	ADD	SI,MaxVect
MemIt4:	POP	BX
	POP	CX
	POP	DX
	POP	DI
	RET
MemItem	ENDP
