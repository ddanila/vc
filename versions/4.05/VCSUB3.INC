	POP	DI
	ADD	DI,2*80
	CALL	NgLine
	POP	BX
	POP	DX
	CALL	Window
	PUSH	ES
	POP	DS
	MOV	DS:CrnPath,0
	CALL	ReadTre
	MOV	AL,DH
	SUB	AL,8
	CALL	TrCr20
	MOV	SI,DS:TreeBuf.TreeLen
	MOV	AL,DH
	SUB	AL,8
	CBW
	SUB	SI,AX
	JAE	ChTr03
