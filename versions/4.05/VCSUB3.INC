ChTr13:	MOV	AL,DH
	SUB	AL,9
	MOV	AH,16
	MUL	AH
	MOV	SI,BP
	SUB	SI,DI
	CMP	SI,AX
	JBE	ChTr14
	MOV	DI,BP
	SUB	DI,AX
ChTr14:	MOV	CX,DI
	XCHG	BP,DS:TreAdr
	XCHG	DI,DS:TreFrst
	SUB	CX,DI
	JNE	ChTr15
	CMP	BP,DS:TreAdr
	JNE	ChTr15
	JMP	ChTr20
ChTr15:	PUSH	BP			; Put lines
	PUSH	DI
	PUSH	DX
	PUSH	CX
	PUSH	BX
	MOV	BP,OFFSET ChTr_P
	CALL	BasAdr
	ADD	DI,2*165
	MOV	CL,DH
	SUB	CL,8
	MOV	CH,0
	MOV	AH,CS:[BP]
	CALL	Color
	MOV	AL,' '
ChTr16:	PUSH	DI
	PUSH	CX
	MOV	CX,38
	REP	STOSW
	POP	CX
	POP	DI
	ADD	DI,2*80
	LOOP	ChTr16
	ADD	BX,104h
	SUB	DX,40Ah
