;-------------- Read directory with save ---------------
;			    DS - WCBseg
;			AL = 0 - Without save
	.CONST
Mask_S	DB	'\*.*',0
Ext_F	DB	'VC.EXT',0

	.CODE
ReDir	PROC	NEAR
	PUSH	BP
	PUSH	SI
	PUSH	DI
	PUSH	DX
	PUSH	CX
	PUSH	BX
	PUSH	AX
	MOV	DS:ChgFlg,1
	CMP	DS:WinTyp,0
	JE	ReDr00
	JMP	RdTree
ReDr00:	PUSH	AX			; Expand WCB
	MOV	BP,ES
	ADD	BP,ES:FreMem2
	MOV	AX,MinView-1
	MOV	CL,4
	SHR	AX,CL
	INC	AX
	SUB	BP,AX
	MOV	CX,DS
	ADD	CX,1000h
	MOV	AX,DS
	MOV	BX,ES:WCB1seg
	CMP	AX,BX
	JB	ReDr03
	MOV	BX,ES:WCB2seg
	CMP	AX,BX
	JB	ReDr03
	CMP	BP,CX
	JBE	ReDr02
	MOV	BP,CX
ReDr02:	MOV	ES:ViewSeg,BP
	JMP	ReDr08
ReDr03:	MOV	AX,ES:ViewSeg
	SUB	AX,BX
	SUB	BP,AX
	CMP	BP,CX
	JBE	ReDr04
	MOV	BP,CX
ReDr04:	PUSH	AX
	ADD	AX,BP
	MOV	ES:ViewSeg,AX
	POP	AX
	MOV	CL,4
	SHL	AX,CL
	MOV	CX,AX
	MOV	SI,AX
	DEC	SI
	MOV	DI,SI
	PUSH	DS
	PUSH	ES
	MOV	DS,BX
	MOV	ES,BP
	STD
	REP	MOVSB
	CLD
	POP	ES
	POP	DS
	CMP	BX,ES:WCB1seg
	JNE	ReDr05
	MOV	ES:WCB1seg,BP
ReDr05:	CMP	BX,ES:WCB2seg
	JNE	ReDr06
	MOV	ES:WCB2seg,BP
ReDr06:	CMP	BX,ES:WCBcrn
	JNE	ReDr07
	MOV	ES:WCBcrn,BP
ReDr07:	CMP	BX,ES:WCBsec
	JNE	ReDr08
	MOV	ES:WCBsec,BP
ReDr08:	MOV	AX,DS			; Save old files
	SUB	BP,AX
	CMP	BP,0FFFh
	JBE	ReDr09
	MOV	BP,0FFFh
ReDr09:	MOV	CL,4
	SHL	BP,CL
	SUB	BP,SIZE FilEnt + SIZE FilEnt
	POP	AX
	MOV	SI,OFFSET DskBuf
	XOR	DI,DI
	PUSH	SI
	PUSH	DI
	PUSH	AX
	MOV	BX,ES:ViewSeg
	MOV	AX,ES
	SUB	BX,AX
	MOV	AX,ES:FreMem2
	SUB	AX,BX
	CMP	AX,0FFFh
	JBE	ReDr10
	MOV	AX,0FFFh
ReDr10:	MOV	CL,4
	SHL	AX,CL
	MOV	CX,SIZE FilEnt
	XOR	DX,DX
	DIV	CX
	MUL	CX
	MOV	CX,DS:EndBuf
	SUB	CX,SI
	MOV	BX,DS:CurAdr
	MOV	DX,DS:First
	CMP	CX,AX
	JBE	ReDr11
	MOV	CX,AX
	ADD	AX,SI
	SUB	AX,SIZE FilEnt
	CMP	BX,AX
	JBE	ReDr11
	MOV	BX,AX
	CMP	DX,AX
	JBE	ReDr11
	MOV	DX,AX
ReDr11:	PUSH	CX
	PUSH	ES
	MOV	ES,ES:ViewSeg
	REP	MOVSB
	POP	ES
	POP	CX
	ADD	CX,OFFSET DskBuf
	XCHG	BX,CX
	POP	AX
	MOV	AH,0			; Read directory
	PUSH	DX
	PUSH	CX
	PUSH	BX
	PUSH	AX
ReDr20:	MOV	SI,OFFSET WinPath
	MOV	DI,OFFSET TmpBuf
	MOV	DX,DI
	CALL	MvzLin0
	CALL	AddFile
	PUSH	DS
	PUSH	CS
	POP	DS
	MOV	SI,OFFSET Mask_S+1
	CALL	MvzLin0
	POP	DS
	XOR	BX,BX
	MOV	DI,OFFSET DskBuf
	CMP	BL,DS:WinPath[3]
	JE	ReDr21
	PUSH	ES
	PUSH	DS
	POP	ES
	MOV	AL,'.'
	STOSB
	STOSB
	MOV	CX,SIZE FilEnt-2
	MOV	AL,0
	REP	STOSB
	MOV	BYTE PTR DS:[DI-SIZE FilEnt+13],10h
	MOV	WORD PTR DS:[DI-SIZE FilEnt+16],182Fh
	INC	BX
	POP	ES
ReDr21:	MOV	AL,DS:WinPath
	SUB	AL,'A'-1
	CALL	Fantom
	JC	ReDr26
	CALL	SetDTA
	PUSH	DS
	PUSH	ES
	POP	DS
	POP	ES
	MOV	CX,37h
	MOV	AH,4Eh
	CALL	Intr21
	JNC	ReDr27
	PUSH	DS
	PUSH	ES
	POP	DS
	POP	ES
	CMP	AX,12h
	JNE	ReDr22
	JMP	ReDr34
ReDr22:	CMP	AX,3
	JNE	ReDr26
	POP	AX
	MOV	AL,0
	INC	AH
	CMP	AH,2
	PUSH	AX
	JA	ReDr26
	JB	ReDr24
ReDr23:	MOV	AL,ES:DosPth[0]
	MOV	DS:WinPath[0],AL
	MOV	DS:WinPath[3],0
ReDr24:	MOV	AL,DS:WinPath[0]
	SUB	AL,'A'-1
	CALL	Fantom
	JC	ReDr26
	MOV	SI,OFFSET WinPath+3
	MOV	DL,AL
	MOV	AH,47h
	CALL	Intr21
	JC	ReDr25
	JMP	ReDr20
ReDr25:	CMP	AX,0Fh
	JE	ReDr23
ReDr26:	POP	AX
	MOV	AL,0
	PUSH	AX
	JMP	ReDr35
ReDr27:	MOV	DS:BlocEr,0		; Save entry
	MOV	SI,OFFSET DTA.FilName
	MOV	AH,DS:DTA.FilAttr
	CMP	BYTE PTR DS:[SI],'.'
	JNE	ReDr28
	TEST	AH,10h
	JZ	ReDr28
	CMP	DS:WinPath[3],0
	JE	ReDr32
	PUSH	DI
	AND	DS:DTA.FilAttr,0F9h
	MOV	DI,OFFSET DskBuf.AttrF
	JMP	ReDr31
ReDr28:	MOV	ES:[DI].NumbF,BX
	INC	BX
	LEA	CX,[DI+SIZE FilEnt]
	PUSH	CX
	MOV	CX,13
ReDr29:	LODSB
	TEST	AH,10h
	JNZ	ReDr30
	PUSH	ES
	PUSH	DS
	POP	ES
	CALL	LowCase
	POP	ES
ReDr30:	STOSB
	LOOP	ReDr29
ReDr31:	MOV	SI,OFFSET DTA.FilAttr
	AND	BYTE PTR DS:[SI],3Fh
	MOV	CX,9
	REP	MOVSB
	POP	DI
ReDr32:	MOV	AH,4Fh			; Find next
	CALL	Intr21
	JC	ReDr33
	CMP	DI,BP
	JB	ReDr27
	CALL	Beep
ReDr33:	PUSH	DS
	PUSH	ES
	POP	DS
	POP	ES
	JNC	ReDr34
	CMP	AX,12h
	JNE	ReDr35
ReDr34:	MOV	DS:ChgFlg,0
ReDr35:	MOV	DS:EndFul,DI
	MOV	DS:EndBuf,DI
	MOV	SI,OFFSET DskBuf
	MOV	DS:CurAdr,SI
	MOV	DS:First,SI
	MOV	ES:BlocEr,0
	CMP	DS:ChgFlg,0		; Read local extension file
	JNZ	ReDr42
	PUSH	DS
	PUSH	ES
	POP	DS
	MOV	DX,OFFSET TmpBuf
	MOV	SI,DX
	CALL	CutPath
	PUSH	CS
	POP	DS
	MOV	DI,SI
	MOV	SI,OFFSET Ext_F
	CALL	MvzLin0
	PUSH	ES
	POP	DS
	MOV	AL,40h
	CALL	OpenFil
	POP	DS
	JC	ReDr41
	MOV	BX,AX
	MOV	DX,OFFSET ExtBuf
	MOV	CX,LenExt-1
	MOV	AH,3Fh
	CALL	Intr21
	PUSHF
	PUSH	AX
	MOV	AH,3Eh
	CALL	Intr21
	POP	BX
	POP	CX
	JC	ReDr41
	PUSH	CX
	POPF
	JC	ReDr41
	MOV	BYTE PTR DS:ExtBuf[BX],1Ah
	JMP	ReDr45
ReDr41:	CMP	AL,53h
	JNE	ReDr42
	MOV	DS:ChgFlg,1
ReDr42:	MOV	SI,OFFSET ExtMain
	MOV	DI,OFFSET ExtBuf
	MOV	CX,LenExt
	PUSH	DS
	PUSH	ES
	POP	DS
	POP	ES
	REP	MOVSB
	PUSH	DS
	PUSH	ES
	POP	DS
	POP	ES
ReDr45:	MOV	AL,0			; Scan directory sizes
	MOV	DS:SizDir,AL
	CMP	AL,DS:ChgFlg
	JNZ	ReDr46
	CMP	AL,ES:AutoSiz
	JZ	ReDr46
	CALL	DirSize
ReDr46:	CALL	SetMask
	CALL	Sort
	POP	AX
	POP	BX
	POP	CX
	POP	DX
	POP	DI
	POP	SI
	SUB	BX,SI			; Restore cursor, selection
	SUB	CX,SI
	SUB	DX,SI
	PUSH	ES
	MOV	ES,ES:ViewSeg
	JMP	ReDr53
ReDr50:	MOV	AH,ES:[DI].AttrF
	AND	AH,0C0h
	JZ	ReDr52
	CMP	AL,0
	JNZ	ReDr51
	AND	AH,80h
	JZ	ReDr52
ReDr51:	CALL	FnFile
	JNC	ReDr52
	OR	DS:[SI].AttrF,AH
ReDr52:	ADD	DI,SIZE FilEnt
ReDr53:	CMP	DI,BX
	JB	ReDr50
	CMP	AL,0
	JZ	ReDr55
	MOV	DI,CX
	CALL	NearFl
	MOV	CX,DS:CurAdr
	JNC	ReDr54
	MOV	CX,SI
	MOV	DS:CurAdr,CX
ReDr54:	MOV	DI,DX
	CALL	NearFl
	JNC	ReDr55
	MOV	DS:First,SI
ReDr55:	POP	ES
	MOV	DI,DS:EndFul		; Compress WCB
	ADD	DI,SIZE FilEnt
	MOV	CL,4
	DEC	DI
	MOV	DX,SIZE WCBdef - 1
	CMP	DI,DX
	JAE	ReDr60
	MOV	DI,DX
ReDr60:	SHR	DI,CL
	INC	DI
	MOV	AX,DS
	ADD	DI,AX
	MOV	BP,DI
	MOV	BX,ES:WCB1seg
	CMP	AX,BX
	JB	ReDr61
	MOV	BX,ES:WCB2seg
	CMP	AX,BX
	JAE	ReDr65
ReDr61:	MOV	AX,ES:ViewSeg
	SUB	AX,BX
	MOV	DX,BP
	ADD	BP,AX
	SHL	AX,CL
	MOV	CX,AX
	MOV	SI,0
	MOV	DI,SI
	PUSH	DS
	PUSH	ES
	MOV	DS,BX
	MOV	ES,DX
	CLD
	REP	MOVSB
	POP	ES
	POP	DS
	CMP	BX,ES:WCB1seg
	JNE	ReDr62
	MOV	ES:WCB1seg,DX
ReDr62:	CMP	BX,ES:WCB2seg
	JNE	ReDr63
	MOV	ES:WCB2seg,DX
ReDr63:	CMP	BX,ES:WCBcrn
	JNE	ReDr64
	MOV	ES:WCBcrn,DX
ReDr64:	CMP	BX,ES:WCBsec
	JNE	ReDr65
	MOV	ES:WCBsec,DX
ReDr65:	MOV	ES:ViewSeg,BP
	CALL	CorPar
ReDr70:	CMP	DS:ChgFlg,1		; Exit
	CMC
	POP	AX
	POP	BX
	POP	CX
	POP	DX
	POP	DI
	POP	SI
	POP	BP
	RET
ReDir	ENDP

RdTree:	CMP	DS:WinTyp,1
	JE	RdTre0
	JMP	RdInfo
RdTre0:	CALL	ReadTre
	JC	RdTre1
	MOV	DS:ChgFlg,0
RdTre1:	JMP	ReDr70

TreeErr	EQU	BYTE PTR TreHead[0]
TreeLev	EQU	BYTE PTR TreHead[1]
DirRecu	EQU	BYTE PTR DirName[12]

	.CONST
Tree_F	DB	'\TREEINFO.NCD',0
TreBeg	DB	'PNCI',0
Scan1_S	DB	'Scanning the directory',0
Scan2_S	DB	'structure on drive ^V:',0
Scan3_S	DB	'0',0
Scan4_S	DB	'Saving the',0
Scan5_S	DB	'directory information...',0

	.DATA
Tree_P	DB	Box_C, 0, 0, 0
	DB	4, 1
	DW	OFFSET ErrBuf
	DW	OFFSET MenuBuf
	DB	0, 25
	DW	OFFSET Tree_S
	DW	OFFSET Scan1_S
	DW	OFFSET Scan2_S
	DW	OFFSET Scan3_S
TrSav_P	DB	Box_C, 0, 0, 0
	DB	3, 0
	DW	OFFSET ErrBuf
	DW	OFFSET Tree_S
	DW	OFFSET Scan4_S
	DW	OFFSET Scan5_S

	.CODE
ReadTre	PROC	NEAR
	PUSH	DS
	PUSH	BP
	PUSH	SI
	PUSH	DI
	PUSH	DX
	PUSH	CX
	PUSH	BX
	PUSH	AX
	CLD
	PUSH	ES
	POP	DS

	MOV	BP,OFFSET TreeBuf+MinTree*SIZE DIRENT+SIZE DIRTREE ; ??? Expand

	MOV	AL,DS:DosPth
	SUB	AL,'A'-1
	CALL	Fantom
	JC	RdTr01
	PUSH	DS			; Reading TREEINFO
	PUSH	CS
	POP	DS
	MOV	DX,OFFSET Tree_F
	MOV	AL,40h
	CALL	OpenFil
	POP	DS
	JNC	RdTr02
	CMP	AX,53h
	JNE	RdTr10
RdTr01:	MOV	DI,OFFSET TreeBuf.TreList
	PUSH	DI
	MOV	CX,SIZE DIRENT
	MOV	AL,0
	REP	STOSB
	POP	DI
	MOV	DS:[DI].DirName,'\'
	MOV	DS:[DI].DirShift,1
	MOV	DS:TreeBuf.TreeLen,1
	MOV	DS:TreeBuf.TreeErr,0
	JMP	RdTr40
RdTr02:	MOV	BX,AX
	MOV	DX,OFFSET TreeBuf
	MOV	CX,BP
	SUB	CX,DX
	MOV	AH,3Fh
	CALL	Intr21
	PUSHF
	PUSH	AX
	MOV	AH,3Eh
	CALL	Intr21
	POP	AX
	POP	SI
	JC	RdTr01
	PUSH	SI
	POPF
	JC	RdTr01
	CMP	AX,CX			; TreeBuf overflow ???
	JAE	RdTr10
	PUSH	DS
	PUSH	CS
	POP	DS
	MOV	SI,OFFSET TreBeg
	MOV	DI,OFFSET TreeBuf.TreHead
	MOV	CX,5
	PUSH	DI
	REPE	CMPSB
	POP	SI
	POP	DS
	JNE	RdTr10
	MOV	BX,DS:[DI]
	MOV	CL,7
	PUSH	AX
	CALL	ChkSum
	CMP	AX,DS:[DI+2]
	POP	AX
	JNE	RdTr10
	MOV	CL,4
	SHL	BX,CL
	SUB	AX,11
	CMP	AX,BX
	JNE	RdTr10
	MOV	CX,BX
	MOV	SI,OFFSET TreeBuf.TreList
	CALL	ChkSum
	CMP	AX,DS:[SI+BX]
	JNE	RdTr10
	JMP	RdTr40
RdTr10:	MOV	DI,OFFSET TreeBuf	; Scanning tree
	MOV	CX,BP
	SUB	CX,DI
	MOV	AL,0
	REP	STOSB
	MOV	DS:ZoomOne,AL
	PUSH	CS
	POP	DS
	MOV	DI,OFFSET MenuBuf+40
	MOV	SI,OFFSET Mask_S
	MOV	CX,5
	REP	MOVSB
	PUSH	ES
	POP	DS
	MOV	DS:TreeBuf.TreList.DirName,'\'
	MOV	DS:TreeBuf.TreList.DirShift,1
	MOV	DI,OFFSET TreeBuf.TreList+SIZE DIRENT
RdTr11:	INC	DS:TreeBuf.TreeLen
	MOV	CX,DS:TreeBuf.TreeLen
	CMP	CX,5
	JB	RdTr13
	JA	RdTr12
	PUSH	BP
	MOV	AL,DS:[DosPth]
	CBW
	MOV	WORD PTR DS:[MenuBuf],AX
	MOV	BX,728h
	MOV	BP,OFFSET Tree_P
	CALL	OncZoom
	POP	BP
RdTr12:	PUSH	DI
	PUSH	BX
	XOR	BX,BX
	MOV	SI,OFFSET MenuBuf
	MOV	DI,SI
	MOV	AL,1
	CALL	Number
	POP	BX
	PUSH	BP
	PUSH	BX
	ADD	BH,4
	MOV	BL,28h
	MOV	BP,OFFSET Tree_P
	CALL	CntLine
	POP	BX
	POP	BP
	PUSH	DX
	PUSH	BX
	ADD	BH,4
	MOV	DH,1
	CALL	Window
	POP	BX
	POP	DX
	POP	DI
RdTr13:	PUSH	DX
	PUSH	BX
	CMP	DS:TreeBuf.TreeLen,1
	JE	RdTr15
RdTr14:	MOV	AH,4Fh
	JMP	RdTr16
RdTr15:	CALL	SetDTA
	MOV	DX,OFFSET MenuBuf+40
	MOV	CX,37h
	MOV	AH,4Eh
RdTr16:	CALL	TstBrk
	MOV	AL,2
	JC	RdTr18
	CALL	Intr21
	JC	RdTr17
	TEST	DS:DTA.FilAttr,10h
	JZ	RdTr14
	CMP	DS:HidDirs,0
	JNZ	RdTr29
	TEST	DS:DTA.FilAttr,2
	JNZ	RdTr14
RdTr29:	MOV	SI,OFFSET DTA.FilName
	CMP	BYTE PTR DS:[SI],'.'
	JE	RdTr14
	LEA	AX,[BP-(OFFSET TreeBuf+SIZE DirTree)-SIZE DirEnt]
	MOV	CL,4
	SHR	AX,CL
	CMP	AX,DS:TreeBuf.TreeLen
	JA	RdTr20
	CALL	Beep
	MOV	AL,0
	JMP	RdTr18
RdTr17:	CMP	AX,53h
	JNE	RdTr22
	MOV	AL,1
RdTr18:	MOV	DS:TreeBuf.TreeErr,AL
	MOV	SI,OFFSET TreeBuf.TreList.DirRecu
RdTr19:	MOV	BYTE PTR DS:[SI],0
	ADD	SI,16
	CMP	SI,BP
	JB	RdTr19
	JMP	RdTr26
RdTr20:	LEA	CX,[BP]-SIZE DIRENT
	SUB	CX,DI
	JBE	RdTr80
	PUSH	SI
	PUSH	DI
	LEA	DI,[BP]-1
	LEA	SI,[DI]-SIZE DIRENT
	STD
	REP	MOVSB
	CLD
	POP	DI
	POP	SI
RdTr80:	MOV	CX,12
	PUSH	DI
	PUSH	CX
	REP	MOVSB
	POP	CX
	POP	SI
	CALL	FilZero
	MOV	AL,0FFh
	STOSB
	MOV	AL,DS:TreeBuf.TreeLev
	INC	AX
	STOSB
	INC	DI
	INC	DI
	CMP	AL,DS:[DI-2*SIZE DIRENT].DirLevel
	MOV	AL,1
	JNE	RdTr21
	MOV	DS:[DI-2*SIZE DIRENT].DirCont,1
	MOV	AL,0
RdTr21:	MOV	DS:[DI-SIZE DIRENT].DirShift,AL
	MOV	DS:[DI-SIZE DIRENT].DirCont,0
	POP	BX
	POP	DX
	JMP	RdTr11
RdTr22:	MOV	AL,0
	CMP	AL,DS:[DI-SIZE DIRENT].DirRecu
	JNE	RdTr23
	CMP	AL,DS:[DI].DirRecu
	JNE	RdTr24
	JMP	RdTr26
RdTr23:	SUB	DI,16
	CMP	AL,DS:[DI-SIZE DIRENT].DirRecu
	JNE	RdTr23
RdTr24:	MOV	DS:[DI].DirRecu,AL
	MOV	CL,DS:[DI].DirLevel
	MOV	DS:TreeBuf.TreeLev,CL
	MOV	CH,0
	PUSH	DI
	MOV	DI,OFFSET MenuBuf+40
RdTr25:	PUSH	CX
	MOV	CX,20
	MOV	AL,'\'
	REPNE	SCASB
	POP	CX
	LOOP	RdTr25
	POP	SI
	PUSH	SI
	MOV	CX,13
	CALL	MvzLine
	PUSH	CS
	POP	DS
	MOV	SI,OFFSET Mask_S
	MOVSB
	MOV	AX,DI
	MOV	CX,4
	REP	MOVSB
	PUSH	ES
	POP	DS
	POP	DI
	ADD	DI,16
	CMP	AX,OFFSET MenuBuf+40+LenPath
	JA	RdTr22
	JMP	RdTr15
RdTr26:	POP	BX
	POP	DX
	CMP	DS:TreeBuf.TreeLen,5
	JB	RdTr30
	MOV	SI,OFFSET ErrBuf
	CALL	ResWin
	CALL	Window
RdTr30:	CMP	DS:TreeBuf.TreeErr,0	; Delete TREEINFO
	JNE	RdTr31
	CMP	ES:TreeBuf.TreeLen,5
	JAE	RdTr32
	PUSH	DS
	PUSH	CS
	POP	DS
	MOV	DX,OFFSET Tree_F
	MOV	AH,41h
	CALL	Intr21
	POP	DS
RdTr31:	JMP	RdTr40
RdTr32:	CALL	TstBrk			; Save TREEINFO
	JC	RdTr31
	MOV	BX,728h
	MOV	BP,OFFSET TrSav_P
	CALL	OncZoom
	PUSH	SI
	PUSH	DX
	PUSH	BX
	PUSH	CS
	POP	DS
	MOV	SI,OFFSET TreBeg
	MOV	DI,OFFSET TreeBuf.TreHead
	MOV	CX,5
	PUSH	DI
	REP	MOVSB
	PUSH	ES
	POP	DS
	POP	SI
	MOV	BX,DS:[DI]
	INC	DI
	INC	DI
	MOV	CL,7
	CALL	ChkSum
	STOSW
	MOV	CL,4
	SHL	BX,CL
	MOV	CX,BX
	MOV	SI,DI
	CALL	ChkSum
	MOV	DS:[SI+BX],AX
	MOV	BX,CX
	ADD	BX,11
	PUSH	CS
	POP	DS
	MOV	DX,OFFSET Tree_F
	MOV	AX,4300h
	CALL	Intr21
	JNC	RdTr34
	CMP	AX,2
	JNE	RdTr37
	XOR	CX,CX
RdTr34:	OR	CL,20h
	MOV	ES:BlocEr,1
	MOV	AH,3Ch
	CALL	Intr21
	JNC	RdTr36
	CMP	AX,5
	JNE	RdTr37
RdTr35:	CALL	Beep
	JMP	RdTr37
RdTr36:	PUSH	ES
	POP	DS
	MOV	CX,BX
	MOV	BX,AX
	MOV	DX,OFFSET TreeBuf
	MOV	AH,40h
	CALL	Intr21
	PUSHF
	PUSH	AX
	MOV	AH,3Eh
	CALL	Intr21
	POP	AX
	POP	BX
	JC	RdTr37
	PUSH	BX
	POPF
	JC	RdTr37
	CMP	AX,CX
	JNE	RdTr35
RdTr37:	MOV	ES:BlocEr,0
	POP	BX
	POP	DX
	POP	SI
	CALL	ResWin
	CALL	Window
RdTr40:	CALL	TreeCur			; Set cursor
	MOV	AL,ES:TreeBuf.TreeErr
	DEC	AX
	CMP	AL,1
					; ??? Compress
	POP	AX
	POP	BX
	POP	CX
	POP	DX
	POP	DI
	POP	SI
	POP	BP
	POP	DS
	RET
ReadTre	ENDP

TreeCur	PROC	NEAR			; Set cursor
	PUSH	DS
	PUSH	ES
	POP	DS
	MOV	AX,OFFSET TreeBuf.TreList
	MOV	DS:TreFrst,AX
	MOV	DS:TreAdr,AX
	CALL	TrCr11
	JNC	TrCr01
	CALL	TrCr10
	JC	TrCr02
TrCr01:	CALL	SizDX
	MOV	AL,DH
	SUB	AL,4
	CALL	TrCr20
TrCr02:	POP	DS
	RET
