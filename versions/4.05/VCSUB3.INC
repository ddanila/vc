	PUSH	BX
	ADD	BH,DH
	SUB	BH,4
	ADD	BL,19
	CMP	DS:WinMous,0
	JNZ	ChTr21
	MOV	CX,12
	MOV	SI,OFFSET MenuBuf+230
	MOV	AH,CS:ChTr_P+1
	CALL	InSt10
ChTr21:	MOV	AX,BX
