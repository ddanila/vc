	PUSH	DS
	PUSH	SI
	PUSH	DI
	PUSH	DX
	PUSH	CX
	PUSH	BX
	CALL	MakeIni
	MOV	BX,CX
	MOV	DX,OFFSET TmpBuf
	MOV	SI,OFFSET Init_F
	MOV	DI,DX
	CALL	MainFil
	CALL	ChgDisk
	JC	SavSt2
	MOV	AX,4300h
	CALL	Intr21
	JNC	SavSt1
	CMP	AX,2
	JNE	SavSt3
	XOR	CX,CX
SavSt1:	OR	CL,20h
	MOV	AH,3Ch
	CALL	Intr21
	JC	SavSt4
	MOV	CX,BX
	MOV	BX,AX
	MOV	DX,OFFSET MenuBuf
	MOV	AH,40h
	CALL	Intr21
	PUSHF
	PUSH	AX
	MOV	AH,3Eh
	CALL	Intr21
	POP	BX
	POP	DX
	JC	SavSt4
	MOV	AX,BX
	PUSH	DX
	POPF
	JC	SavSt4
	CMP	AX,CX
	JE	SavSt4
SavSt2:	MOV	AL,0
SavSt3:	STC
SavSt4:	POP	BX
	POP	CX
	POP	DX
	POP	DI
	POP	SI
	POP	DS
	RET
SaveSet	ENDP

MakeIni	PROC	NEAR
	PUSH	DI
	PUSH	AX
	MOV	DI,OFFSET MenuBuf
	PUSH	DI
	MOV	AL,'V'
	STOSB
	STOSB
	STOSB
	MOV	DS,ES:WCB1seg
	CALL	MkIni1
	MOV	DS,ES:WCB2seg
	CALL	MkIni1
	PUSH	ES
	POP	DS
	MOV	SI,0
	MOV	CX,CmnIni
	REP	MOVSB
	POP	SI
	MOV	CX,DI
	SUB	CX,SI
	CALL	ChkSum
	STOSW
	INC	CX
	INC	CX
	POP	AX
	POP	DI
	RET
MakeIni	ENDP

MkIni1	PROC	NEAR
	MOV	SI,OFFSET DskMas
	MOV	CX,13
	CALL	FilZero
	MOV	SI,OFFSET WinPath
	MOV	CX,LenPath
	CALL	FilZero
	XOR	SI,SI
	MOV	CX,WCBini
	REP	MOVSB
	RET
MkIni1	ENDP

