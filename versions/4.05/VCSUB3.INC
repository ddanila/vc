	MOV	BP,SI
	JMP	ChTr10

ChTr55:	PUSH	DX			; Rescan
	PUSH	BX
	ADD	BX,205h
	SUB	DX,80Ch
	MOV	CL,DH
	MOV	CH,0
	MOV	BP,OFFSET ChTr_P
