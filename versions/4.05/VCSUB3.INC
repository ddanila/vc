	MOV	DX,16
	MOV	SI,DS:TreAdr
	CALL	Search
	POP	BX
	POP	DX
	JZ	ChTr20
	MOV	BP,SI
	MOV	DI,DS:TreFrst
	JMP	ChTr12
ChTr22:	JMP	ChTr60

ChTr30:	XOR	BP,BP			; Home
