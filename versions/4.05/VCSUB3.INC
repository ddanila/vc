	MOV	AX,440Eh
	INT	21h
	JC	Fantm1
	CMP	AL,0
	JE	Fantm1
	CMP	AL,BL
	JE	Fantm1
	MOV	BH,AL
	MOV	AX,440Fh
	INT	21h
	JC	Fantm1
	CMP	AL,BH
	JE	Fantm1
	XCHG	BL,BH
	MOV	AX,440Fh
	INT	21h
	JC	Fantm1
